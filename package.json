{
  "name": "jsof",
  "version": "1.0.0",
  "description": "liberal JSON",
  "main": "lib",
  "scripts": {
    "test": "eslint lib test && node --test",
    "coverage": "node --test --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=lcov.info",
    "bundle": "esbuild lib/index.js --bundle --format=iife --global-name=jsof --minify --outfile=build/jsof.js",
    "prepublishOnly": "npm run test && npm run bundle"
  },
  "files": [
    "build/jsof.js",
    "lib/*"
  ],
  "unpkg": "build/jsof.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/drom/jsof.git"
  },
  "keywords": [
    "JSON"
  ],
  "author": "alex.drom@gmail.com",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/drom/jsof/issues"
  },
  "homepage": "https://github.com/drom/jsof#readme",
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.15.0"
  },
  "dependencies": {}
}
